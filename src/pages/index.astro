---
import Layout from '../layouts/Layout.astro';
import LeadForm from '../components/LeadForm.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('guides', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date - a.data.date)
  .slice(0, 3);
const thumbs = ['', 'b2', 'b3'];
---
<Layout current="home">
  <!-- HERO -->
  <section class="hero">
    <svg class="shore" viewBox="0 0 400 700" fill="none" aria-hidden="true">
      <path d="M400 0 C 250 90, 330 200, 230 300 C 150 380, 260 470, 170 560 C 110 620, 200 660, 150 700 L400 700 Z" fill="#15315E" opacity=".07"/>
      <path d="M400 30 C 270 120, 340 220, 250 320 C 180 395, 280 485, 200 575 C 150 630, 230 670, 190 700" stroke="#15315E" stroke-width="1.4" opacity=".25"/>
      <g fill="#2456C9">
        <circle cx="300" cy="150" r="5"/><circle cx="252" cy="320" r="5"/><circle cx="232" cy="470" r="5"/><circle cx="205" cy="595" r="5"/>
      </g>
    </svg>
    <div class="wrap hero-grid">
      <div>
        <p class="eyebrow">Southeast Wisconsin · Personal agent matching</p>
        <h1>Get Personally Matched With a <em>Trusted</em> Local Agent.</h1>
        <p class="lead">Tell us about your move and a real person reaches out. After a genuine conversation about your goals, we connect you with the right local agent and resources. A tailored fit, never a name pulled from a queue.</p>
        <ul class="hero-trust">
          <li><span class="dot"></span> Vetted local agents</li>
          <li><span class="dot"></span> Free for homeowners</li>
          <li><span class="dot"></span> No obligation</li>
        </ul>
      </div>
      <LeadForm />
    </div>
  </section>

  <!-- TRUST BAR -->
  <div class="trustbar">
    <div class="wrap">
      <span><b>Licensed</b> Wisconsin agents</span>
      <span><b>8</b> counties covered</span>
      <span><b>$0</b> cost to homeowners</span>
      <span><b>Local</b>, not a national call center</span>
    </div>
  </div>

  <!-- HOW IT WORKS -->
  <section class="section">
    <div class="wrap">
      <div class="section-head">
        <p class="eyebrow">A personal process</p>
        <h2>How RRS Connects You</h2>
        <p>No anonymous lead queue, no random handoff. A real person guides you from first hello to the right agent, here's how.</p>
      </div>
      <div class="steps">
        <div class="step"><div class="num">1</div><h3>Tell Us About Your Move</h3><p>Share a few quick details about your situation, where you are, your timeline, and what you're hoping to do. It takes about a minute.</p></div>
        <div class="step"><div class="num">2</div><h3>We Reach Out and Listen</h3><p>A real person from RRS contacts you for a genuine conversation, not a form dropped into a pool. We take time to understand your goals, your home, and what matters most to you.</p></div>
        <div class="step"><div class="num">3</div><h3>We Connect You With the Right Agent</h3><p>We partner with a team of trusted agents across Southeast Wisconsin. Based on that conversation, we personally connect you with the right one for your situation, plus any other resources you need. A tailored fit, with no pressure and no obligation.</p></div>
      </div>
    </div>
  </section>

  <!-- SERVICE AREA -->
  <section class="section area">
    <div class="wrap split">
      <div>
        <p class="eyebrow">Where we work</p>
        <h2>Built for Southeast Wisconsin</h2>
        <p class="intro">From the lakefront to the Kettle Moraine, we match homeowners and buyers across the eight counties of Southeast Wisconsin with agents who live and work here.</p>
        <ul class="cities">
          <li>Milwaukee</li><li>Waukesha</li><li>New Berlin</li><li>Brookfield</li><li>Wauwatosa</li><li>West Allis</li><li>Racine</li><li>Kenosha</li><li>Mukwonago</li><li>Oak Creek</li><li>Menomonee Falls</li><li>Cedarburg</li><li>Pewaukee</li><li>Muskego</li><li>Franklin</li><li>Germantown</li>
        </ul>
      </div>
      <div class="map-card">
        <svg viewBox="0 0 460 360" fill="none" aria-label="Map of the Southeast Wisconsin service area" role="img">
          <rect width="460" height="360" rx="10" fill="#F7F9FC"/>
          <path d="M360 0 C 330 70, 360 150, 320 230 C 295 290, 330 330, 300 360 L460 360 L460 0 Z" fill="#15315E" opacity=".10"/>
          <text x="395" y="200" fill="#15315E" opacity=".4" font-family="Spectral" font-size="13" transform="rotate(90 395 200)">LAKE MICHIGAN</text>
          <g stroke="#15315E" stroke-opacity=".18" stroke-width="1.2">
            <rect x="40" y="40" width="130" height="120"/><rect x="170" y="40" width="130" height="120"/>
            <rect x="40" y="160" width="130" height="120"/><rect x="170" y="160" width="130" height="120"/>
            <rect x="40" y="280" width="130" height="60"/><rect x="170" y="280" width="130" height="60"/>
          </g>
          <g>
            <circle cx="250" cy="120" r="7" fill="#2456C9"/><text x="262" y="124" font-family="Libre Franklin" font-size="13" font-weight="600" fill="#15315E">Milwaukee</text>
            <circle cx="110" cy="150" r="6" fill="#15315E"/><text x="120" y="154" font-family="Libre Franklin" font-size="12" fill="#274A82">Waukesha</text>
            <circle cx="150" cy="200" r="6" fill="#15315E"/><text x="160" y="204" font-family="Libre Franklin" font-size="12" fill="#274A82">New Berlin</text>
            <circle cx="245" cy="300" r="6" fill="#15315E"/><text x="150" y="304" font-family="Libre Franklin" font-size="12" fill="#274A82">Racine · Kenosha</text>
            <circle cx="230" cy="60" r="6" fill="#15315E"/><text x="105" y="64" font-family="Libre Franklin" font-size="12" fill="#274A82">Ozaukee · Wash.</text>
          </g>
        </svg>
      </div>
    </div>
  </section>

  <!-- WHY -->
  <section class="section">
    <div class="wrap">
      <div class="section-head">
        <p class="eyebrow">Why homeowners use us</p>
        <h2>The Local Advantage, Without the Legwork</h2>
        <p>One quick form replaces hours of researching, comparing, and second-guessing which agent to trust.</p>
      </div>
      <div class="why-grid">
        <div class="why-card"><div class="ic">📍</div><h3>Truly Local Agents</h3><p>We match you with agents who work your specific area, not out-of-town crews chasing leads two counties over.</p></div>
        <div class="why-card"><div class="ic">🛡️</div><h3>Vetted and Licensed</h3><p>Every agent we recommend is a licensed Wisconsin professional with a real track record we've checked.</p></div>
        <div class="why-card"><div class="ic">🤝</div><h3>No Pressure, Ever</h3><p>You're never obligated to list or buy. Get matched, ask questions, and decide entirely on your own timeline.</p></div>
        <div class="why-card"><div class="ic">💸</div><h3>Free for You</h3><p>Our matching service costs homeowners nothing. We're here to make a stressful decision a little easier.</p></div>
        <div class="why-card"><div class="ic">⚡</div><h3>A Real Person, Not a Queue</h3><p>You're never dropped into an anonymous lead pool. We reach out personally, talk it through, and guide you to the right fit.</p></div>
        <div class="why-card"><div class="ic">🧭</div><h3>Honest Guidance First</h3><p>Read our local guides before you ever fill out a form. Informed homeowners make better moves.</p></div>
      </div>
    </div>
  </section>

  <!-- GUIDES -->
  <section class="section area">
    <div class="wrap">
      <div class="section-head">
        <p class="eyebrow">Local guides</p>
        <h2>Know Before You Move</h2>
        <p>Straight answers to the questions Southeast Wisconsin homeowners and buyers actually ask.</p>
      </div>
      <div class="blog-grid">
        {posts.map((post, i) => (
          <a class="post" href={`/guides/${post.slug}/`}>
            <div class={`thumb ${thumbs[i] || ''}`}><span>{post.data.category}</span></div>
            <div class="body">
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
              <div class="more">Read the guide →</div>
            </div>
          </a>
        ))}
      </div>
      <div class="center"><a class="btn btn-ghost" href="/guides/">View all guides →</a></div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta">
    <div class="wrap">
      <h2>Ready to Find Your Agent?</h2>
      <p>Get matched with a trusted Southeast Wisconsin real estate agent today. Free, no obligation, no pressure.</p>
      <a class="btn btn-primary" href="/get-started/">Find my agent →</a>
    </div>
  </section>
</Layout>
