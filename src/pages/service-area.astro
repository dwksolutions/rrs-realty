---
import Layout from '../layouts/Layout.astro';
import { citiesByCounty } from '../data/cities.js';

// Driven entirely by src/data/cities.js so the areas we serve always match the
// cities that have a market-data page. Add a city there and it appears here too.
const counties = citiesByCounty();
---
<Layout
  current="area"
  title="Service Area, Southeast Wisconsin Real Estate | RRS Realty Group"
  description="RRS Realty Group matches homeowners and buyers with local agents across all eight Southeast Wisconsin counties: Milwaukee, Waukesha, Ozaukee, Washington, Racine, Kenosha, Walworth and Jefferson."
>
  <section class="page-head">
    <div class="wrap">
      <p class="eyebrow">Where we work</p>
      <h1>Serving All of Southeast Wisconsin</h1>
      <p>We match homeowners and buyers with local agents across the region's eight counties, people who actually live and work where you do.</p>
    </div>
  </section>

  <section class="section" style="padding-top:44px">
    <div class="wrap">
      <div class="map-card" style="max-width:560px;margin:0 auto 56px">
        <svg viewBox="0 0 490 460" fill="none" aria-label="Map of the 49 Southeast Wisconsin cities we serve across eight counties, along Lake Michigan" role="img">
          <path d="M45.3 40.4 L345.1 40.4 L342.5 105.2 L339.8 213.2 L337.2 234.8 L353 303.2 L363.5 346.4 L355.6 400.4 L350.3 440 L350.3 440 L45.3 440 Z" fill="#E7EEFA" stroke="#15315E" stroke-opacity=".28" stroke-width="1.2"/>
          <path d="M345.1 40.4 L342.5 105.2 L339.8 213.2 L337.2 234.8 L353 303.2 L363.5 346.4 L355.6 400.4 L350.3 440 L480 440 L480 40.4 Z" fill="#C7D9F1"/>
          <text x="455" y="249.2" fill="#2456C9" opacity=".7" font-family="Spectral" font-size="13" font-style="italic" text-anchor="middle" transform="rotate(90 455 249.2)">Lake Michigan</text>
          <g font-family="Spectral" font-style="italic" fill="#15315E" opacity=".34" font-size="11" text-anchor="middle">
            <text x="224.1" y="87.2">Washington</text>
            <text x="305.6" y="130.4">Ozaukee</text>
            <text x="92.6" y="231.2">Jefferson</text>
            <text x="224.1" y="202.4">Waukesha</text>
            <text x="150.5" y="357.2">Walworth</text>
            <text x="289.9" y="321.2">Racine</text>
            <text x="263.5" y="411.2">Kenosha</text>
          </g>
          <g font-family="Libre Franklin">
            <circle cx="326.7" cy="234.8" r="5.5" fill="#15315E" stroke="#fff" stroke-width="1.5"/>
            <text x="335.7" y="238.8" font-size="11.5" font-weight="700" fill="#15315E">Milwaukee</text>
            <circle cx="303" cy="231.2" r="2.6" fill="#2456C9" opacity=".75"/>
            <circle cx="303" cy="242" r="2.6" fill="#2456C9" opacity=".75"/>
            <circle cx="300.4" cy="263.6" r="2.6" fill="#2456C9" opacity=".75"/>
            <circle cx="339.8" cy="288.8" r="2.6" fill="#2456C9" opacity=".75"/>
            <circle cx="295.1" cy="288.8" r="2.6" fill="#2456C9" opacity=".75"/>
            <circle cx="331.9" cy="216.8" r="2.6" fill="#2456C9" opacity=".75"/>
            <circle cx="329.3" cy="209.6" r="2.6" fill="#2456C9" opacity=".75"/>
            <circle cx="321.4" cy="202.4" r="2.6" fill="#2456C9" opacity=".75"/>
            <circle cx="289.9" cy="270.8" r="2.6" fill="#2456C9" opacity=".75"/>
            <circle cx="339.8" cy="263.6" r="2.6" fill="#2456C9" opacity=".75"/>
            <circle cx="339.8" cy="281.6" r="2.6" fill="#2456C9" opacity=".75"/>
            <circle cx="242.5" cy="245.6" r="3.4" fill="#2456C9"/>
            <text x="234.5" y="249.1" font-size="10.5" font-weight="600" fill="#274A82" text-anchor="end">Waukesha</text>
            <circle cx="274.1" cy="227.6" r="2.6" fill="#2456C9" opacity=".75"/>
            <circle cx="274.1" cy="256.4" r="2.6" fill="#2456C9" opacity=".75"/>
            <circle cx="271.4" cy="184.4" r="2.6" fill="#2456C9" opacity=".75"/>
            <circle cx="234.6" cy="220.4" r="2.6" fill="#2456C9" opacity=".75"/>
            <circle cx="266.2" cy="285.2" r="2.6" fill="#2456C9" opacity=".75"/>
            <circle cx="197.8" cy="227.6" r="2.6" fill="#2456C9" opacity=".75"/>
            <circle cx="213.6" cy="213.2" r="2.6" fill="#2456C9" opacity=".75"/>
            <circle cx="282" cy="231.2" r="2.6" fill="#2456C9" opacity=".75"/>
            <circle cx="216.2" cy="299.6" r="2.6" fill="#2456C9" opacity=".75"/>
            <circle cx="313.5" cy="170" r="3.4" fill="#2456C9"/>
            <text x="321.5" y="173.5" font-size="10.5" font-weight="600" fill="#274A82" text-anchor="start">Mequon</text>
            <circle cx="305.6" cy="141.2" r="2.6" fill="#2456C9" opacity=".75"/>
            <circle cx="316.1" cy="134" r="2.6" fill="#2456C9" opacity=".75"/>
            <circle cx="337.2" cy="108.8" r="2.6" fill="#2456C9" opacity=".75"/>
            <circle cx="318.8" cy="112.4" r="2.6" fill="#2456C9" opacity=".75"/>
            <circle cx="255.7" cy="98" r="3.4" fill="#2456C9"/>
            <text x="247.7" y="101.5" font-size="10.5" font-weight="600" fill="#274A82" text-anchor="end">West Bend</text>
            <circle cx="274.1" cy="166.4" r="2.6" fill="#2456C9" opacity=".75"/>
            <circle cx="205.7" cy="134" r="2.6" fill="#2456C9" opacity=".75"/>
            <circle cx="258.3" cy="134" r="2.6" fill="#2456C9" opacity=".75"/>
            <circle cx="226.7" cy="130.4" r="2.6" fill="#2456C9" opacity=".75"/>
            <circle cx="360.9" cy="346.4" r="3.4" fill="#2456C9"/>
            <text x="368.9" y="349.9" font-size="10.5" font-weight="600" fill="#274A82" text-anchor="start">Racine</text>
            <circle cx="334.6" cy="350" r="2.6" fill="#2456C9" opacity=".75"/>
            <circle cx="326.7" cy="321.2" r="2.6" fill="#2456C9" opacity=".75"/>
            <circle cx="229.4" cy="364.4" r="2.6" fill="#2456C9" opacity=".75"/>
            <circle cx="329.3" cy="357.2" r="2.6" fill="#2456C9" opacity=".75"/>
            <circle cx="350.3" cy="400.4" r="3.4" fill="#2456C9"/>
            <text x="358.3" y="403.9" font-size="10.5" font-weight="600" fill="#274A82" text-anchor="start">Kenosha</text>
            <circle cx="321.4" cy="411.2" r="2.6" fill="#2456C9" opacity=".75"/>
            <circle cx="237.3" cy="422" r="2.6" fill="#2456C9" opacity=".75"/>
            <circle cx="189.9" cy="396.8" r="3.4" fill="#2456C9"/>
            <text x="181.9" y="400.3" font-size="10.5" font-weight="600" fill="#274A82" text-anchor="end">Lake Geneva</text>
            <circle cx="161" cy="368" r="2.6" fill="#2456C9" opacity=".75"/>
            <circle cx="134.7" cy="382.4" r="2.6" fill="#2456C9" opacity=".75"/>
            <circle cx="111" cy="310.4" r="2.6" fill="#2456C9" opacity=".75"/>
            <circle cx="197.8" cy="324.8" r="2.6" fill="#2456C9" opacity=".75"/>
            <circle cx="111" cy="180.8" r="3.4" fill="#2456C9"/>
            <text x="103" y="184.3" font-size="10.5" font-weight="600" fill="#274A82" text-anchor="end">Watertown</text>
            <circle cx="82.1" cy="274.4" r="2.6" fill="#2456C9" opacity=".75"/>
            <circle cx="90" cy="249.2" r="2.6" fill="#2456C9" opacity=".75"/>
            <circle cx="63.7" cy="220.4" r="2.6" fill="#2456C9" opacity=".75"/>
          </g>
        </svg>
      </div>

      <div class="why-grid">
        {counties.map((group) => (
          <div class="why-card">
            <h3>{group.county}</h3>
            <p class="county-cities">
              {group.cities.map((c, i) => (
                <Fragment>{i > 0 ? ' · ' : ''}<a href={`/home-values/${c.slug}/`}>{c.name}</a></Fragment>
              ))}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="cta">
    <div class="wrap">
      <h2>Don't See Your Town?</h2>
      <p>If you're anywhere in Southeast Wisconsin, reach out, chances are we can match you with a local agent nearby.</p>
      <a class="btn btn-primary" href="/get-started/">Find my agent →</a>
    </div>
  </section>
</Layout>
