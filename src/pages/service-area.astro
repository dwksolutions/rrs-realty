---
import Layout from '../layouts/Layout.astro';

const counties = [
  { name: 'Milwaukee County', cities: 'Milwaukee · Wauwatosa · West Allis · Greenfield · Oak Creek · Franklin · Hales Corners · Cudahy · South Milwaukee · Glendale · Whitefish Bay · Shorewood' },
  { name: 'Waukesha County', cities: 'Waukesha · New Berlin · Brookfield · Menomonee Falls · Pewaukee · Muskego · Delafield · Hartland · Elm Grove · Mukwonago' },
  { name: 'Ozaukee County', cities: 'Cedarburg · Mequon · Grafton · Port Washington · Saukville' },
  { name: 'Washington County', cities: 'West Bend · Germantown · Hartford · Jackson · Slinger' },
  { name: 'Racine County', cities: 'Racine · Mount Pleasant · Caledonia · Burlington · Sturtevant' },
  { name: 'Kenosha County', cities: 'Kenosha · Pleasant Prairie · Somers · Twin Lakes' },
  { name: 'Walworth County', cities: 'Lake Geneva · Elkhorn · Delavan · Whitewater · East Troy' },
  { name: 'Jefferson County', cities: 'Watertown · Fort Atkinson · Jefferson · Lake Mills' },
];
---
<Layout
  current="area"
  title="Service Area — Southeast Wisconsin Real Estate | RRS Realty Group"
  description="RRS Realty Group matches homeowners and buyers with local agents across all eight Southeast Wisconsin counties: Milwaukee, Waukesha, Ozaukee, Washington, Racine, Kenosha, Walworth and Jefferson."
>
  <section class="page-head">
    <div class="wrap">
      <p class="eyebrow">Where we work</p>
      <h1>Serving All of Southeast Wisconsin</h1>
      <p>We match homeowners and buyers with local agents across the region's eight counties — people who actually live and work where you do.</p>
    </div>
  </section>

  <section class="section" style="padding-top:44px">
    <div class="wrap">
      <div class="map-card" style="max-width:560px;margin:0 auto 56px">
        <svg viewBox="0 0 460 360" fill="none" aria-label="Map of the Southeast Wisconsin service area" role="img">
          <rect width="460" height="360" rx="10" fill="#F7F9FC"/>
          <path d="M360 0 C 330 70, 360 150, 320 230 C 295 290, 330 330, 300 360 L460 360 L460 0 Z" fill="#15315E" opacity=".10"/>
          <text x="395" y="200" fill="#15315E" opacity=".4" font-family="Spectral" font-size="13" transform="rotate(90 395 200)">LAKE MICHIGAN</text>
          <g stroke="#15315E" stroke-opacity=".18" stroke-width="1.2">
            <rect x="40" y="40" width="130" height="120"/><rect x="170" y="40" width="130" height="120"/>
            <rect x="40" y="160" width="130" height="120"/><rect x="170" y="160" width="130" height="120"/>
            <rect x="40" y="280" width="130" height="60"/><rect x="170" y="280" width="130" height="60"/>
          </g>
          <g>
            <circle cx="250" cy="120" r="7" fill="#2456C9"/><text x="262" y="124" font-family="Libre Franklin" font-size="13" font-weight="600" fill="#15315E">Milwaukee</text>
            <circle cx="110" cy="150" r="6" fill="#15315E"/><text x="120" y="154" font-family="Libre Franklin" font-size="12" fill="#274A82">Waukesha</text>
            <circle cx="150" cy="200" r="6" fill="#15315E"/><text x="160" y="204" font-family="Libre Franklin" font-size="12" fill="#274A82">New Berlin</text>
            <circle cx="245" cy="300" r="6" fill="#15315E"/><text x="150" y="304" font-family="Libre Franklin" font-size="12" fill="#274A82">Racine · Kenosha</text>
            <circle cx="230" cy="60" r="6" fill="#15315E"/><text x="105" y="64" font-family="Libre Franklin" font-size="12" fill="#274A82">Ozaukee · Wash.</text>
          </g>
        </svg>
      </div>

      <div class="why-grid">
        {counties.map((c) => (
          <div class="why-card">
            <h3>{c.name}</h3>
            <p>{c.cities}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="cta">
    <div class="wrap">
      <h2>Don't See Your Town?</h2>
      <p>If you're anywhere in Southeast Wisconsin, reach out — chances are we can match you with a local agent nearby.</p>
      <a class="btn btn-primary" href="/get-started/">Find my agent →</a>
    </div>
  </section>
</Layout>
