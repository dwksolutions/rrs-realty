---
import Layout from '../layouts/Layout.astro';
import { citiesByCounty } from '../data/cities.js';

// Driven entirely by src/data/cities.js so the areas we serve always match the
// cities that have a market-data page. Add a city there and it appears here too.
const counties = citiesByCounty();
---
<Layout
  current="area"
  title="Service Area, Southeast Wisconsin Real Estate | RRS Realty Group"
  description="RRS Realty Group matches homeowners and buyers with local agents across all eight Southeast Wisconsin counties: Milwaukee, Waukesha, Ozaukee, Washington, Racine, Kenosha, Walworth and Jefferson."
>
  <section class="page-head">
    <div class="wrap">
      <p class="eyebrow">Where we work</p>
      <h1>Serving All of Southeast Wisconsin</h1>
      <p>We match homeowners and buyers with local agents across the region's eight counties, people who actually live and work where you do.</p>
    </div>
  </section>

  <section class="section" style="padding-top:44px">
    <div class="wrap">
      <div class="map-card" style="max-width:560px;margin:0 auto 56px">
        <svg viewBox="0 0 480 380" fill="none" aria-label="Map of the eight Southeast Wisconsin counties we serve, bordering Lake Michigan" role="img">
          <rect width="480" height="380" rx="10" fill="#F2F6FC"/>

          <!-- Lake Michigan (east) -->
          <path d="M362 10 C 346 58, 378 106, 358 154 C 342 198, 376 246, 358 294 C 346 334, 370 358, 362 370 L470 370 L470 10 Z" fill="#CBDCF3"/>
          <g fill="#FFFFFF" opacity=".55" stroke="none">
            <path d="M392 70 q 10 -8 20 0" stroke="#1E3D7B" stroke-width="1" fill="none" opacity=".5"/>
            <path d="M400 130 q 10 -8 20 0" stroke="#1E3D7B" stroke-width="1" fill="none" opacity=".5"/>
            <path d="M392 250 q 10 -8 20 0" stroke="#1E3D7B" stroke-width="1" fill="none" opacity=".5"/>
            <path d="M400 310 q 10 -8 20 0" stroke="#1E3D7B" stroke-width="1" fill="none" opacity=".5"/>
          </g>
          <text x="426" y="190" fill="#2456C9" opacity=".7" font-family="Spectral" font-size="13" font-style="italic" text-anchor="middle" transform="rotate(90 426 190)">Lake Michigan</text>

          <!-- County tiles, positioned geographically. Top-left (Dodge Co.) is outside the area. -->
          <g font-family="Libre Franklin">
            <!-- Row 1 -->
            <g>
              <rect x="120" y="16" width="120" height="112" rx="6" fill="#E3ECFA" stroke="#15315E" stroke-opacity=".22"/>
              <text x="180" y="68" text-anchor="middle" font-size="13" font-weight="600" fill="#15315E">Washington</text>
              <text x="180" y="86" text-anchor="middle" font-size="11" fill="#5C6A82">West Bend</text>
            </g>
            <g>
              <rect x="244" y="16" width="116" height="112" rx="6" fill="#E3ECFA" stroke="#15315E" stroke-opacity=".22"/>
              <text x="302" y="68" text-anchor="middle" font-size="13" font-weight="600" fill="#15315E">Ozaukee</text>
              <text x="302" y="86" text-anchor="middle" font-size="11" fill="#5C6A82">Mequon</text>
            </g>
            <!-- Row 2 -->
            <g>
              <rect x="16" y="132" width="100" height="112" rx="6" fill="#E3ECFA" stroke="#15315E" stroke-opacity=".22"/>
              <text x="66" y="184" text-anchor="middle" font-size="13" font-weight="600" fill="#15315E">Jefferson</text>
              <text x="66" y="202" text-anchor="middle" font-size="11" fill="#5C6A82">Watertown</text>
            </g>
            <g>
              <rect x="120" y="132" width="120" height="112" rx="6" fill="#E3ECFA" stroke="#15315E" stroke-opacity=".22"/>
              <text x="180" y="184" text-anchor="middle" font-size="13" font-weight="600" fill="#15315E">Waukesha</text>
              <text x="180" y="202" text-anchor="middle" font-size="11" fill="#5C6A82">Waukesha</text>
            </g>
            <g>
              <rect x="244" y="132" width="116" height="112" rx="6" fill="#15315E"/>
              <text x="302" y="182" text-anchor="middle" font-size="13.5" font-weight="700" fill="#FFFFFF">Milwaukee</text>
              <text x="302" y="200" text-anchor="middle" font-size="11" fill="#AEC2DE">Milwaukee</text>
            </g>
            <!-- Row 3 -->
            <g>
              <rect x="16" y="248" width="100" height="112" rx="6" fill="#E3ECFA" stroke="#15315E" stroke-opacity=".22"/>
              <text x="66" y="300" text-anchor="middle" font-size="13" font-weight="600" fill="#15315E">Walworth</text>
              <text x="66" y="318" text-anchor="middle" font-size="11" fill="#5C6A82">Lake Geneva</text>
            </g>
            <g>
              <rect x="120" y="248" width="120" height="112" rx="6" fill="#E3ECFA" stroke="#15315E" stroke-opacity=".22"/>
              <text x="180" y="300" text-anchor="middle" font-size="13" font-weight="600" fill="#15315E">Racine</text>
              <text x="180" y="318" text-anchor="middle" font-size="11" fill="#5C6A82">Racine</text>
            </g>
            <g>
              <rect x="244" y="248" width="116" height="112" rx="6" fill="#E3ECFA" stroke="#15315E" stroke-opacity=".22"/>
              <text x="302" y="300" text-anchor="middle" font-size="13" font-weight="600" fill="#15315E">Kenosha</text>
              <text x="302" y="318" text-anchor="middle" font-size="11" fill="#5C6A82">Kenosha</text>
            </g>
          </g>
        </svg>
      </div>

      <div class="why-grid">
        {counties.map((group) => (
          <div class="why-card">
            <h3>{group.county}</h3>
            <p class="county-cities">
              {group.cities.map((c, i) => (
                <Fragment>{i > 0 ? ' · ' : ''}<a href={`/home-values/${c.slug}/`}>{c.name}</a></Fragment>
              ))}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="cta">
    <div class="wrap">
      <h2>Don't See Your Town?</h2>
      <p>If you're anywhere in Southeast Wisconsin, reach out, chances are we can match you with a local agent nearby.</p>
      <a class="btn btn-primary" href="/get-started/">Find my agent →</a>
    </div>
  </section>
</Layout>
