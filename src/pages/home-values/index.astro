---
import Layout from '../../layouts/Layout.astro';
import { citiesByCounty } from '../../data/cities.js';

const counties = citiesByCounty();

const title = 'Southeast Wisconsin Market Data by City | RRS Realty Group';
const description = 'Explore home values and market trends across Southeast Wisconsin: median sale prices, days on market, and price per square foot by city. Get a free local home valuation.';
---
<Layout current="values" title={title} description={description}>
  <section class="page-head">
    <div class="wrap">
      <p class="eyebrow">Market data</p>
      <h1>Southeast Wisconsin Home Values</h1>
      <p>Median prices and market trends by city. Pick your town for a local snapshot, then get a free valuation of your specific home.</p>
    </div>
  </section>

  <section class="section" style="padding-top:44px">
    <div class="wrap" style="max-width:60rem">
      {counties.map((group) => (
        <div class="mkt-group">
          <h2>{group.county}</h2>
          <div class="mkt-pills">
            {group.cities.map((c) => (
              <a href={`/home-values/${c.slug}/`}>{c.name}</a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="cta">
    <div class="wrap">
      <h2>Want Your Home's Real Value?</h2>
      <p>Market averages are a starting point. Get matched with a local agent for a free, no-obligation valuation of your specific home.</p>
      <a class="btn btn-primary" href="/get-started/">Find my agent →</a>
    </div>
  </section>
</Layout>
