---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import '../styles/global.css';

const {
  title = 'RRS Realty Group — Trusted Southeast Wisconsin Real Estate Agents',
  description = 'Get matched with a vetted, licensed local real estate agent in Southeast Wisconsin. Free for homeowners and buyers. No obligation, no pressure.',
  current = '',
  ogType = 'website',
  image = '/logo.png',
  publishedTime,
  jsonLd = [],
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(image, Astro.site).href;
const origin = new URL(Astro.site).origin;

const counties = [
  'Milwaukee County', 'Waukesha County', 'Ozaukee County', 'Washington County',
  'Racine County', 'Kenosha County', 'Walworth County', 'Jefferson County',
];

const business = {
  '@type': 'RealEstateAgent',
  '@id': origin + '/#business',
  name: 'RRS Realty Group',
  description: 'Connects Southeast Wisconsin homeowners and buyers with vetted, licensed local real estate agents. Free agent matching, no obligation.',
  url: origin,
  logo: ogImage,
  image: ogImage,
  email: 'rrsrealtygroup@gmail.com',
  priceRange: 'Free',
  address: { '@type': 'PostalAddress', addressRegion: 'WI', addressCountry: 'US' },
  areaServed: counties.map((name) => ({ '@type': 'AdministrativeArea', name: name + ', Wisconsin' })),
  knowsAbout: ['Real estate', 'Selling a home', 'Buying a home', 'Home valuation', 'Choosing a real estate agent', 'Southeast Wisconsin housing market'],
};

const website = {
  '@type': 'WebSite',
  '@id': origin + '/#website',
  name: 'RRS Realty Group',
  url: origin,
  publisher: { '@id': origin + '/#business' },
};

const schemaGraph = { '@context': 'https://schema.org', '@graph': [business, website, ...jsonLd] };
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta name="robots" content="index, follow, max-image-preview:large" />

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:site_name" content="RRS Realty Group" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:locale" content="en_US" />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:alt" content="RRS Realty Group — Southeast Wisconsin real estate agent matching" />
  {publishedTime && <meta property="article:published_time" content={publishedTime} />}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Spectral:ital,wght@0,500;0,600;0,700;1,500&family=Libre+Franklin:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="apple-touch-icon" href="/logo.png" />
  <meta name="theme-color" content="#15315E" />

  <!-- Structured data (business + website + any page-specific schema) -->
  <script type="application/ld+json" set:html={JSON.stringify(schemaGraph)} />
</head>
<body>
  <Header current={current} />
  <main>
    <slot />
  </main>
  <Footer />
  <CookieBanner />
</body>
</html>
