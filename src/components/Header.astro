---
const { current = '' } = Astro.props;
const link = (href, label, key) =>
  `<a href="${href}"${current === key ? ' aria-current="page"' : ''}>${label}</a>`;
---
<header class="site">
  <div class="wrap nav">
    <a class="brand" href="/">
      <span class="mark">RRS</span>
      <span><span class="bt">RRS Realty Group</span><span class="bs">Southeast Wisconsin</span></span>
    </a>
    <nav class="nav-links" id="navlinks" aria-label="Primary">
      <a href="/how-it-works/" {...current === 'how' ? { 'aria-current': 'page' } : {}}>How it works</a>
      <a href="/service-area/" {...current === 'area' ? { 'aria-current': 'page' } : {}}>Service area</a>
      <a href="/about/" {...current === 'about' ? { 'aria-current': 'page' } : {}}>About</a>
      <a href="/guides/" {...current === 'guides' ? { 'aria-current': 'page' } : {}}>Guides</a>
    </nav>
    <div class="nav-cta">
      <a class="btn btn-ghost" href="/get-started/">Contact</a>
      <a class="btn btn-primary" href="/get-started/">Find my agent</a>
    </div>
    <button class="menu-btn" aria-label="Toggle menu" aria-expanded="false" id="menubtn">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>
<script>
  const btn = document.getElementById('menubtn');
  const links = document.getElementById('navlinks');
  btn?.addEventListener('click', () => {
    const open = links?.classList.toggle('open');
    btn.setAttribute('aria-expanded', String(!!open));
  });
</script>
